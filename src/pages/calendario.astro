---
import BaseLayout from '~/layouts/BaseLayout.astro';
import Separator from '~/components/Separator.astro';
import { getImperialMonth, getImperialYear } from '~/utils/calendar';

const now = new Date();
const { year } = getImperialYear(now);
const month = getImperialMonth(now);

const FEASTS = [
  { date: '02-25', name: 'Dies Victoriae',           desc: 'Conmemoración de la resolución fundacional del Autocrátor: la victoria del Orden sobre la indeterminación, anterior a la Fundación del Reino.' },
  { date: '03-01', name: 'Dies Fundationis',          desc: 'Fundación del Sacratísimo Reino Soberano de Eucategarion, Año I E.O.E.' },
  { date: '03-07', name: 'Dies Coronationis',         desc: 'Coronación del Autócrator Alexion I en el Palacio del Trono.' },
  { date: '03-08', name: 'Dies Domus Eucategarianae', desc: 'Día de la Casa Eucategariana y de los vínculos que sostienen el Reino.' },
  { date: '03-31', name: 'Dies Ordinis',              desc: 'Promulgación del Liber Ordinis Eucategarionis. Día de meditación sobre los fundamentos del Reino.' },
];
---

<BaseLayout
  title="Calendario | Reino Soberano de Eucategarion"
  description="Calendarium Imperiale Eucategarionis — fechas del sistema E.O.E. y festividades imperiales."
>

  <!-- Dies Hodierna -->
  <section class="cal-hodierna">
    <p class="cal-hod-eyebrow">Calendarium Imperiale · Dies Hodierna</p>
    <p class="cal-hod-date" id="cal-hodierna-date"></p>
    <div class="cal-hod-rule"></div>
  </section>

  <!-- Month navigation header -->
  <section class="cal-header-section">
    <div class="cal-month-nav">
      <button class="cal-nav-btn" id="cal-prev" aria-label="Mes anterior">&#8249;</button>
      <div class="cal-month-display">
        <h1 class="cal-month-name" id="cal-month-name">{month}</h1>
        <p class="cal-year-name" id="cal-year-name">Año {year} · E.O.E.</p>
      </div>
      <button class="cal-nav-btn" id="cal-next" aria-label="Mes siguiente">&#8250;</button>
    </div>
    <div class="cal-header-rule"></div>
  </section>

  <!-- Calendar grid -->
  <section class="cal-section">
    <div class="cal-wrapper">
      <div class="cal-grid" id="cal-grid">
        {['Lun', 'Mar', 'Mié', 'Jue', 'Vie', 'Sáb', 'Dom'].map(d => (
          <div class="cal-wday">{d}</div>
        ))}
      </div>
    </div>
  </section>

  <Separator />

  <!-- Feast days -->
  <section class="feasts-section">
    <header class="feasts-header">
      <p class="feasts-eyebrow">Festividades Imperiales</p>
      <h2 class="feasts-title">Dies Solemnes Regni</h2>
      <div class="feasts-rule"></div>
    </header>
    <div class="feasts-list">
      {FEASTS.map((f, i) => (
        <div class="feast-entry">
          <div class="feast-entry-num">{String(i + 1).padStart(2, '0')}</div>
          <div class="feast-entry-date">{f.date.replace('-', '·')}</div>
          <div class="feast-entry-body">
            <h3>{f.name}</h3>
            <p>{f.desc}</p>
          </div>
        </div>
      ))}
    </div>
  </section>

  <Separator />

</BaseLayout>

<script>
  import { IMPERIAL_MONTHS, IMPERIAL_MONTHS_SHORT, toRoman } from '~/utils/calendar';

  const FOUNDATION = 2026;

  const FEASTS: Record<string, string> = {
    '02-25': 'Dies Victoriae',
    '03-01': 'Dies Fundationis',
    '03-07': 'Dies Coronationis',
    '03-08': 'Dies Domus',
    '03-31': 'Dies Ordinis',
  };

  const today = new Date();
  let curYear  = today.getFullYear();
  let curMonth = today.getMonth();

  function pad(n: number) { return String(n).padStart(2, '0'); }

  function imperialYear(civilYear: number): string {
    const imp = civilYear - FOUNDATION + 1;
    return toRoman(imp < 1 ? Math.abs(imp - 1) : imp) + (imp < 1 ? ' A.O.E.' : ' E.O.E.');
  }

  function imperialShort(date: Date): string {
    const m = IMPERIAL_MONTHS_SHORT[date.getMonth()];
    return `${m} · ${imperialYear(date.getFullYear())}`;
  }

  function feastKey(date: Date): string {
    return `${pad(date.getMonth() + 1)}-${pad(date.getDate())}`;
  }

  // Fill "Dies Hodierna" banner
  function renderHodierna() {
    const el = document.getElementById('cal-hodierna-date');
    if (!el) return;
    const d   = today.getDate();
    const m   = IMPERIAL_MONTHS[today.getMonth()];
    const imp = today.getFullYear() - FOUNDATION + 1;
    const y   = toRoman(Math.abs(imp < 1 ? imp - 1 : imp));
    const era = imp < 1 ? 'A.O.E.' : 'E.O.E.';
    el.textContent = `Día ${d} · ${m} · Año ${y} ${era}`;
  }

  function render() {
    const grid   = document.getElementById('cal-grid')!;
    const nameEl = document.getElementById('cal-month-name')!;
    const yearEl = document.getElementById('cal-year-name')!;

    nameEl.textContent = IMPERIAL_MONTHS[curMonth];
    const imp = curYear - FOUNDATION + 1;
    yearEl.textContent = `Año ${toRoman(Math.abs(imp < 1 ? imp - 1 : imp))} · ${imp < 1 ? 'A.O.E.' : 'E.O.E.'}`;

    while (grid.children.length > 7) grid.removeChild(grid.lastChild!);

    const firstDay = new Date(curYear, curMonth, 1);
    const lastDay  = new Date(curYear, curMonth + 1, 0);
    const startOffset = (firstDay.getDay() + 6) % 7;

    for (let i = 0; i < startOffset; i++) {
      const d = new Date(curYear, curMonth, 1 - (startOffset - i));
      const cell = document.createElement('div');
      cell.className = 'cal-day cal-day--other';
      cell.innerHTML = `<span class="cal-civil">${d.getDate()}</span>`;
      grid.appendChild(cell);
    }

    for (let d = 1; d <= lastDay.getDate(); d++) {
      const date  = new Date(curYear, curMonth, d);
      const fkey  = feastKey(date);
      const feast = FEASTS[fkey];
      const isToday = (
        curYear  === today.getFullYear() &&
        curMonth === today.getMonth() &&
        d        === today.getDate()
      );

      const cell = document.createElement('div');
      cell.className = 'cal-day';
      if (feast)   cell.classList.add('cal-day--feast');
      if (isToday) cell.classList.add('cal-day--today');

      cell.innerHTML = `
        <span class="cal-civil">${d}</span>
        <span class="cal-imperial">${imperialShort(date)}</span>
        ${feast ? `<span class="cal-feast-tag">${feast}</span>` : ''}
      `;
      grid.appendChild(cell);
    }

    const filled = startOffset + lastDay.getDate();
    const rem = Math.ceil(filled / 7) * 7 - filled;
    for (let i = 1; i <= rem; i++) {
      const cell = document.createElement('div');
      cell.className = 'cal-day cal-day--other';
      cell.innerHTML = `<span class="cal-civil">${i}</span>`;
      grid.appendChild(cell);
    }
  }

  document.getElementById('cal-prev')?.addEventListener('click', () => {
    curMonth--;
    if (curMonth < 0) { curMonth = 11; curYear--; }
    render();
  });

  document.getElementById('cal-next')?.addEventListener('click', () => {
    curMonth++;
    if (curMonth > 11) { curMonth = 0; curYear++; }
    render();
  });

  renderHodierna();
  render();
</script>

<style>
  /* ── Dies Hodierna ── */
  .cal-hodierna {
    background: #5a0f1b;
    padding: 2.5rem 2rem 2rem;
    text-align: center;
  }

  .cal-hod-eyebrow {
    font-family: 'Cardo', serif;
    font-size: 0.55rem;
    letter-spacing: 0.5em;
    text-transform: uppercase;
    color: rgba(198,167,94,0.45);
    margin: 0 0 1.2rem;
  }

  .cal-hod-date {
    font-family: 'Cardo', serif;
    font-size: clamp(1.4rem, 3.5vw, 2.4rem);
    font-weight: 700;
    letter-spacing: 0.06em;
    color: #f4f1e8;
    margin: 0 0 2rem;
    line-height: 1;
  }

  .cal-hod-rule {
    max-width: 320px;
    margin: 0 auto;
    height: 5px;
    background:
      linear-gradient(rgba(198,167,94,0.6), rgba(198,167,94,0.6)) 0 0 / 100% 3px no-repeat,
      linear-gradient(rgba(198,167,94,0.2), rgba(198,167,94,0.2)) 0 4px / 100% 1px no-repeat;
  }

  /* ── Month navigation header ── */
  .cal-header-section {
    background: #0b0b0d;
    padding: 2.5rem 2rem 0;
  }

  .cal-month-nav {
    display: flex;
    align-items: center;
    justify-content: center;
    max-width: 1100px;
    margin: 0 auto;
    gap: 2.5rem;
    padding-bottom: 2rem;
  }

  .cal-nav-btn {
    font-family: 'Cardo', serif;
    font-size: 1.6rem;
    line-height: 1;
    color: rgba(198,167,94,0.45);
    background: none;
    border: 1px solid rgba(198,167,94,0.18);
    width: 44px;
    height: 44px;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    transition: all 0.2s;
    flex-shrink: 0;
  }

  .cal-nav-btn:hover {
    color: #c6a75e;
    border-color: rgba(198,167,94,0.45);
    background: rgba(198,167,94,0.05);
  }

  .cal-month-display { text-align: center; }

  .cal-month-name {
    font-family: 'Cardo', serif;
    font-size: clamp(1.4rem, 2.8vw, 2.2rem);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.2em;
    color: #f4f1e8;
    margin: 0 0 0.3rem;
    line-height: 1;
  }

  .cal-year-name {
    font-family: 'Cardo', serif;
    font-style: italic;
    font-size: 0.85rem;
    color: rgba(198,167,94,0.5);
    margin: 0;
    letter-spacing: 0.1em;
  }

  .cal-header-rule {
    max-width: 1100px;
    margin: 0 auto;
    height: 5px;
    background:
      linear-gradient(rgba(198,167,94,0.45), rgba(198,167,94,0.45)) 0 0 / 100% 3px no-repeat,
      linear-gradient(rgba(198,167,94,0.15), rgba(198,167,94,0.15)) 0 4px / 100% 1px no-repeat;
  }

  /* ── Calendar grid ── */
  .cal-section {
    background: #f4f1e8;
    padding: 2.5rem 2rem 3rem;
  }

  .cal-wrapper {
    max-width: 1100px;
    margin: 0 auto;
    border: 1px solid rgba(198,167,94,0.25);
    box-shadow: 0 4px 32px rgba(90,15,27,0.08);
  }

  .cal-grid {
    display: grid;
    grid-template-columns: repeat(7, 1fr);
  }

  .cal-wday {
    background: #5a0f1b;
    color: rgba(198,167,94,0.8);
    font-family: 'Cardo', serif;
    font-size: 0.6rem;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    text-align: center;
    padding: 0.9rem 0;
  }

  :global(.cal-day) {
    min-height: 100px;
    padding: 0.65rem 0.75rem;
    border: 1px solid rgba(198,167,94,0.1);
    background: #f9f7f2;
    position: relative;
    transition: background 0.2s;
  }

  :global(.cal-day:hover) { background: rgba(198,167,94,0.05); }

  :global(.cal-day--other) {
    background: rgba(244,241,232,0.4);
    opacity: 0.3;
    pointer-events: none;
  }

  :global(.cal-day--today) {
    background: rgba(198,167,94,0.05);
    border-color: rgba(198,167,94,0.4);
  }

  :global(.cal-day--today::before) {
    content: '';
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 2px;
    background: #c6a75e;
  }

  :global(.cal-day--feast) {
    background: #07090f;
    border-color: rgba(198,167,94,0.18);
  }

  :global(.cal-day--feast:hover) { background: #0e1118; }

  :global(.cal-civil) {
    display: block;
    font-family: 'Cardo', serif;
    font-size: 1.45rem;
    font-weight: 700;
    color: #5a0f1b;
    line-height: 1;
  }

  :global(.cal-day--feast .cal-civil) { color: #c6a75e; }
  :global(.cal-day--other .cal-civil) { color: #b0a090; }

  :global(.cal-imperial) {
    display: block;
    font-family: 'Cardo', serif;
    font-style: italic;
    font-size: 0.58rem;
    color: rgba(198,167,94,0.55);
    margin-top: 0.2rem;
    line-height: 1.3;
  }

  :global(.cal-day--other .cal-imperial) { display: none; }

  :global(.cal-feast-tag) {
    display: block;
    font-family: 'Cardo', serif;
    font-size: 0.58rem;
    letter-spacing: 0.07em;
    text-transform: uppercase;
    color: rgba(198,167,94,0.8);
    margin-top: 0.45rem;
    line-height: 1.3;
    border-top: 1px solid rgba(198,167,94,0.2);
    padding-top: 0.35rem;
  }

  /* ── Feast days section ── */
  .feasts-section {
    background: #0b0b0d;
    padding: 4rem 2rem 5rem;
    border-top: 1px solid rgba(198,167,94,0.1);
  }

  .feasts-header {
    text-align: center;
    margin-bottom: 4rem;
  }

  .feasts-eyebrow {
    font-family: 'Cardo', serif;
    font-size: 0.55rem;
    letter-spacing: 0.5em;
    text-transform: uppercase;
    color: rgba(198,167,94,0.35);
    margin: 0 0 1rem;
  }

  .feasts-title {
    font-family: 'Cardo', serif;
    font-size: clamp(1.2rem, 3vw, 1.8rem);
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: #f4f1e8;
    margin: 0 0 2rem;
  }

  .feasts-rule {
    width: 120px;
    margin: 0 auto;
    height: 5px;
    background:
      linear-gradient(rgba(198,167,94,0.45), rgba(198,167,94,0.45)) 0 0 / 100% 3px no-repeat,
      linear-gradient(rgba(198,167,94,0.15), rgba(198,167,94,0.15)) 0 4px / 100% 1px no-repeat;
  }

  .feasts-list {
    max-width: 760px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .feast-entry {
    display: grid;
    grid-template-columns: 36px 64px 1fr;
    gap: 1.75rem;
    padding: 2rem 0;
    border-bottom: 1px solid rgba(198,167,94,0.07);
    align-items: start;
  }

  .feast-entry:last-child { border-bottom: none; }

  .feast-entry-num {
    font-family: 'Cardo', serif;
    font-size: 0.62rem;
    letter-spacing: 0.1em;
    color: rgba(198,167,94,0.2);
    padding-top: 0.15rem;
    text-align: right;
    font-style: italic;
  }

  .feast-entry-date {
    font-family: 'Courier New', monospace;
    font-size: 0.66rem;
    letter-spacing: 0.1em;
    color: rgba(198,167,94,0.45);
    padding-top: 0.15rem;
    text-align: right;
    border-right: 1px solid rgba(198,167,94,0.1);
  }

  .feast-entry-body h3 {
    font-family: 'Cardo', serif;
    font-size: 1.1rem;
    font-weight: 700;
    color: rgba(244,241,232,0.9);
    margin: 0 0 0.4rem;
    letter-spacing: 0.04em;
    font-style: italic;
  }

  .feast-entry-body p {
    font-family: 'Cormorant Garamond', serif;
    font-size: 0.8rem;
    color: rgba(244,241,232,0.35);
    margin: 0;
    line-height: 1.7;
  }

  /* ── Mobile ── */
  @media (max-width: 700px) {
    .cal-month-nav { grid-template-columns: 48px 1fr 48px; gap: 0.75rem; }
    .cal-month-name { font-size: clamp(1.4rem, 7vw, 2rem); letter-spacing: 0.08em; }
    .cal-day { min-height: 68px; padding: 0.4rem; }
    .cal-civil { font-size: 1.1rem; }
    .cal-imperial { font-size: 0.5rem; }
    .cal-feast-tag { font-size: 0.48rem; }
    .feast-entry { grid-template-columns: 24px 48px 1fr; gap: 1rem; }
  }

  @media (max-width: 480px) {
    .cal-day { min-height: 54px; padding: 0.3rem; }
    .cal-civil { font-size: 0.95rem; }
    .cal-imperial { display: none; }
    .cal-feast-tag { font-size: 0.46rem; padding-top: 0.2rem; }
    .cal-wday { font-size: 0.5rem; padding: 0.6rem 0; letter-spacing: 0.08em; }
    .feast-entry { grid-template-columns: 1fr; gap: 0.4rem; }
    .feast-entry-num { display: none; }
    .feast-entry-date { text-align: left; border-right: none; padding-top: 0; }
  }
</style>
