---
import BaseLayout from '~/layouts/BaseLayout.astro';
import Separator from '~/components/Separator.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const docs = await getCollection('legislacion');
  const sorted = [...docs].sort((a, b) => (a.data.order ?? 99) - (b.data.order ?? 99));
  return sorted.map((doc, i) => ({
    params: { slug: doc.id.replace(/\.mdx?$/, '') },
    props: {
      doc,
      prev: sorted[i - 1] ?? null,
      next: sorted[i + 1] ?? null,
    },
  }));
}

const { doc, prev, next } = Astro.props;
const { Content } = await render(doc);
const { code, title, type, subject, imperialDate, status } = doc.data;
---

<BaseLayout
  title={`${code} — ${title} | Legislación de Eucategarion`}
  description={`${type}: ${title}. ${subject}. ${imperialDate}. ${status}.`}
>
  <div class="ld-page">

    <!-- Breadcrumb -->
    <nav class="ld-breadcrumb" aria-label="Ruta">
      <a href="/legislacion" class="ld-back">← Archivo legislativo</a>
      <span class="ld-bc-sep" aria-hidden="true">/</span>
      <span class="ld-bc-code">{code}</span>
    </nav>

    <!-- Document -->
    <article class="ld-doc">

      <!-- Letterhead -->
      <div class="ld-letterhead">
        <div class="ld-lh-left">
          <p class="ld-lh-kingdom">Sacratísimo Reino Soberano de Eucategarion</p>
          <p class="ld-lh-org">Cancillería Imperial · Archivo Metropolitano</p>
        </div>
        <svg class="ld-lh-crest" width="32" height="40" viewBox="0 0 80 100" fill="none" aria-hidden="true">
          <polygon points="16,30 16,14 27,22 40,8 53,22 64,14 64,30" fill="#c6a75e" opacity="0.7"/>
          <rect x="14" y="25" width="52" height="9" rx="1" fill="#c6a75e" opacity="0.7"/>
          <path d="M 4,34 H 76 V 68 Q 76,96 40,100 Q 4,96 4,68 Z" fill="#5a0f1b"/>
          <path d="M 4,34 H 76 V 68 Q 76,96 40,100 Q 4,96 4,68 Z" fill="none" stroke="#c6a75e" stroke-width="4" opacity="0.7"/>
          <rect x="23" y="47" width="7"  height="40" fill="#c6a75e" opacity="0.7"/>
          <rect x="23" y="47" width="30" height="7"  fill="#c6a75e" opacity="0.7"/>
          <rect x="23" y="63" width="22" height="6"  fill="#c6a75e" opacity="0.7"/>
          <rect x="23" y="80" width="30" height="7"  fill="#c6a75e" opacity="0.7"/>
        </svg>
      </div>

      <!-- Document header -->
      <div class="ld-header">
        <div class="ld-header-top">
          <span class="ld-code">{code}</span>
          <span class="ld-status">{status}</span>
        </div>
        <div class="ld-rule"></div>
        <h1 class="ld-title">{title}</h1>
        <div class="ld-meta">
          <span>{type}</span>
          <span class="ld-meta-sep">·</span>
          <span>{subject}</span>
          <span class="ld-meta-sep">·</span>
          <span>{imperialDate}</span>
        </div>
      </div>

      <!-- Content -->
      <div class="ld-content">
        <Content />
      </div>

      <!-- Footer seal -->
      <footer class="ld-footer">
        <span class="ld-footer-text">
          Registrado en el Archivo Metropolitano Imperial ·
          Cancillería del Sacratísimo Reino Soberano de Eucategarion
        </span>
        <span class="ld-seal" aria-hidden="true">
          <svg viewBox="0 0 40 40" width="40" height="40" fill="none">
            <circle cx="20" cy="20" r="18" stroke="#c6a75e" stroke-width="1" opacity="0.4"/>
            <circle cx="20" cy="20" r="13" stroke="#c6a75e" stroke-width="0.5" opacity="0.25"/>
            <text x="20" y="24" text-anchor="middle" font-size="11" font-family="Georgia, serif" fill="#c6a75e" opacity="0.5">E</text>
          </svg>
        </span>
      </footer>

    </article>

    <!-- Navigation between documents -->
    <nav class="ld-docnav" aria-label="Navegar entre documentos">
      <div class="ld-docnav-prev">
        {prev && (
          <a href={`/legislacion/${prev.id.replace(/\.mdx?$/, '')}`} class="ld-docnav-link">
            <span class="ld-dn-dir">← Anterior</span>
            <span class="ld-dn-code">{prev.data.code}</span>
            <span class="ld-dn-title">{prev.data.title}</span>
          </a>
        )}
      </div>
      <a href="/legislacion" class="ld-docnav-index">Archivo legislativo</a>
      <div class="ld-docnav-next">
        {next && (
          <a href={`/legislacion/${next.id.replace(/\.mdx?$/, '')}`} class="ld-docnav-link ld-docnav-link--next">
            <span class="ld-dn-dir">Siguiente →</span>
            <span class="ld-dn-code">{next.data.code}</span>
            <span class="ld-dn-title">{next.data.title}</span>
          </a>
        )}
      </div>
    </nav>

    <Separator />
  </div>
</BaseLayout>

<style>
  .ld-page {
    background: #f4f1e8;
    min-height: 100vh;
  }

  /* Breadcrumb */
  .ld-breadcrumb {
    max-width: 860px;
    margin: 0 auto;
    padding: 1.75rem 2rem 0;
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  .ld-back {
    font-family: 'Cardo', serif;
    font-size: 0.72rem;
    letter-spacing: 0.1em;
    color: #5a0f1b;
    text-decoration: none;
    opacity: 0.6;
    transition: opacity 0.2s;
  }

  .ld-back:hover { opacity: 1; text-decoration: none; }

  .ld-bc-sep {
    color: rgba(198,167,94,0.4);
    font-size: 0.72rem;
  }

  .ld-bc-code {
    font-family: 'Courier New', monospace;
    font-size: 0.7rem;
    color: #c6a75e;
    letter-spacing: 0.1em;
  }

  /* Document card */
  .ld-doc {
    max-width: 860px;
    margin: 1.5rem auto 0;
    border: 1px solid rgba(198,167,94,0.3);
    background: #f9f7f2;
  }

  /* Letterhead */
  .ld-letterhead {
    background: #5a0f1b;
    padding: 0.7rem 1.75rem;
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 1rem;
  }

  .ld-lh-kingdom {
    font-family: 'Cardo', serif;
    font-size: 0.62rem;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    color: rgba(198,167,94,0.85);
    margin: 0 0 0.15rem;
  }

  .ld-lh-org {
    font-family: 'Cormorant Garamond', serif;
    font-size: 0.58rem;
    color: rgba(244,241,232,0.38);
    margin: 0;
    letter-spacing: 0.05em;
  }

  /* Document header */
  .ld-header {
    padding: 2rem 2rem 1.5rem;
    border-bottom: 1px solid rgba(198,167,94,0.25);
  }

  .ld-header-top {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 1rem;
  }

  .ld-code {
    font-family: 'Courier New', monospace;
    font-size: 0.8rem;
    letter-spacing: 0.14em;
    color: #5a0f1b;
    border: 1px solid rgba(90,15,27,0.2);
    padding: 0.15rem 0.6rem;
    background: rgba(198,167,94,0.06);
  }

  .ld-status {
    font-family: 'Cardo', serif;
    font-size: 0.6rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: #c6a75e;
    border: 1px solid rgba(198,167,94,0.45);
    padding: 0.12rem 0.6rem;
  }

  /* Double rule */
  .ld-rule {
    height: 5px;
    margin-bottom: 1.25rem;
    background:
      linear-gradient(#5a0f1b, #5a0f1b) 0 0 / 100% 3px no-repeat,
      linear-gradient(rgba(198,167,94,0.5), rgba(198,167,94,0.5)) 0 4px / 100% 1px no-repeat;
  }

  .ld-title {
    font-family: 'Cardo', serif;
    font-size: clamp(1.2rem, 3vw, 1.6rem);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: #5a0f1b;
    margin: 0 0 0.75rem;
    line-height: 1.2;
  }

  .ld-meta {
    display: flex;
    flex-wrap: wrap;
    gap: 0.3rem 0;
    font-family: 'Cardo', serif;
    font-style: italic;
    font-size: 0.8rem;
    color: #7a5a65;
    align-items: center;
  }

  .ld-meta-sep {
    color: rgba(198,167,94,0.4);
    margin: 0 0.4rem;
    font-style: normal;
  }

  /* Content */
  .ld-content {
    padding: 2rem 2rem 1.5rem;
    font-size: 0.97rem;
    line-height: 1.85;
    text-align: justify;
    hyphens: auto;
  }

  .ld-content p { margin-bottom: 1rem; }

  .ld-content p:first-child::first-letter {
    float: left;
    font-family: 'Cardo', serif;
    font-size: 3.8rem;
    line-height: 0.82;
    margin: 0.06em 0.12em 0 0;
    color: #5a0f1b;
    font-weight: 700;
    border-left: 3px solid #c6a75e;
    padding: 0 3px 0 0;
  }

  .ld-content strong { font-family: 'Cardo', serif; color: #5a0f1b; }
  .ld-content em { font-style: italic; }

  .ld-content ol, .ld-content ul {
    list-style: none; padding: 0; margin: 0.5rem 0 1rem;
  }

  .ld-content ol { counter-reset: art; }

  .ld-content ol li {
    padding: 0.5rem 0 0.5rem 2.5rem;
    position: relative;
    border-bottom: 1px solid rgba(198,167,94,0.1);
    counter-increment: art;
  }

  .ld-content ol li:last-child { border-bottom: none; }

  .ld-content ol li::before {
    content: counter(art) '.';
    position: absolute;
    left: 0;
    font-family: 'Cardo', serif;
    font-size: 0.82rem;
    color: rgba(198,167,94,0.7);
  }

  /* Footer */
  .ld-footer {
    margin: 0 2rem 1.75rem;
    padding-top: 1.25rem;
    border-top: 1px solid rgba(198,167,94,0.25);
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 1rem;
  }

  .ld-footer-text {
    font-family: 'Cardo', serif;
    font-size: 0.7rem;
    font-style: italic;
    color: #9a7a85;
    letter-spacing: 0.02em;
  }

  /* Document navigation */
  .ld-docnav {
    max-width: 860px;
    margin: 2.5rem auto;
    padding: 0 2rem;
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    gap: 1rem;
    align-items: center;
  }

  .ld-docnav-link {
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
    text-decoration: none;
  }

  .ld-docnav-link--next { text-align: right; }

  .ld-dn-dir {
    font-family: 'Cardo', serif;
    font-size: 0.62rem;
    letter-spacing: 0.15em;
    color: rgba(198,167,94,0.55);
    text-transform: uppercase;
  }

  .ld-dn-code {
    font-family: 'Courier New', monospace;
    font-size: 0.68rem;
    color: rgba(198,167,94,0.55);
  }

  .ld-dn-title {
    font-family: 'Cardo', serif;
    font-size: 0.88rem;
    color: #5a0f1b;
    font-weight: 700;
    transition: color 0.2s;
    line-height: 1.2;
  }

  .ld-docnav-link:hover .ld-dn-title { color: #c6a75e; text-decoration: none; }

  .ld-docnav-index {
    font-family: 'Cardo', serif;
    font-size: 0.7rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: #5a0f1b;
    text-decoration: none;
    border-bottom: 1px solid rgba(198,167,94,0.4);
    padding-bottom: 1px;
    white-space: nowrap;
    opacity: 0.6;
    transition: opacity 0.2s;
  }

  .ld-docnav-index:hover { opacity: 1; text-decoration: none; }

  @media (max-width: 600px) {
    .ld-doc { margin: 1rem; }
    .ld-breadcrumb { padding: 1.25rem 1rem 0; }
    .ld-header { padding: 1.5rem 1.25rem 1.25rem; }
    .ld-content { padding: 1.5rem 1.25rem; }
    .ld-footer { margin: 0 1.25rem 1.5rem; flex-direction: column; align-items: flex-start; gap: 0.75rem; }
    .ld-docnav { grid-template-columns: 1fr; padding: 0 1.25rem; }
    .ld-docnav-next { order: -1; }
    .ld-docnav-link--next { text-align: left; }
    .ld-docnav-index { justify-self: center; }
    .ld-title { font-size: 1.1rem; letter-spacing: 0.03em; }
  }
</style>
