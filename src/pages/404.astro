---
import BaseLayout from '~/layouts/BaseLayout.astro';
---

<BaseLayout title="Página no encontrada | Reino Soberano de Eucategarion">
  <div class="container">
    <div class="not-found">
      <img src="/escudo.png" alt="Escudo del Reino" class="not-found-crest" />
      <span class="not-found-ornament">── ✧ ──</span>
      <h1 class="not-found-title">Página no encontrada</h1>
      <p class="not-found-text">
        El recurso solicitado no existe en el Archivo Metropolitano.<br />
        <em>La ausencia de un documento no prueba la ausencia del Orden.</em>
      </p>
      <a href="/" class="btn-gold" style="margin-top: 2rem;">Regresar al Trono</a>
    </div>
  </div>
</BaseLayout>

<style>
  .not-found {
    text-align: center;
    padding: 7rem 2rem;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1rem;
  }

  .not-found-crest {
    width: 90px;
    opacity: 0.6;
    margin-bottom: 1rem;
  }

  .not-found-ornament {
    font-family: 'Cardo', serif;
    color: #c6a75e;
    font-size: 0.85rem;
    letter-spacing: 0.4em;
  }

  .not-found-title {
    font-family: 'Cardo', serif;
    font-size: clamp(2rem, 5vw, 3.5rem);
    color: #5a0f1b;
    margin: 0;
  }

  .not-found-text {
    color: #4a2a34;
    max-width: 48ch;
    font-style: italic;
    line-height: 1.7;
  }
</style>
