---
import BaseLayout from '~/layouts/BaseLayout.astro';
import Hero from '~/components/Hero.astro';
import { provinces } from '~/utils/provinces';
---

<BaseLayout
  title="Gobierno del Reino | Reino Soberano de Eucategarion"
  description="Las cinco Provincias Mayores del Sacratísimo Reino Soberano de Eucategarion: Orden, Fides, Elevación, Artes y Tradición, y Expansión Digital."
>

  <Hero
    title="Gobierno del Reino"
    subtitle="La administración visible del Orden en la Metrópolis y en las Provincias."
    image="/gobierno-consejo.png"
    imageAlt="Sala del consejo administrativo del Reino"
  />

  <!-- Principio de Gobierno — tres statements en dark -->
  <section class="gb-principles">
    <div class="gb-principles-inner">
      <p class="gb-eyebrow">Principio de Gobierno</p>
      <div class="gb-principles-grid" data-stagger>
        <div class="gb-principle">
          <span class="gb-p-num">I</span>
          <p>El Gobierno no constituye el fundamento del Orden; constituye su instrumento visible.</p>
        </div>
        <div class="gb-p-divider"></div>
        <div class="gb-principle">
          <span class="gb-p-num">II</span>
          <p>Toda autoridad administrativa participa de la autoridad superior del Trono, pero ejerce funciones delimitadas y específicas.</p>
        </div>
        <div class="gb-p-divider"></div>
        <div class="gb-principle">
          <span class="gb-p-num">III</span>
          <p>La estructura gubernativa existe para organizar, ejecutar, supervisar y administrar el Orden en las Provincias.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- La Metrópolis — split dark/image -->
  <section class="gb-metropolis">
    <div class="gb-metro-content" data-reveal="left">
      <p class="gb-eyebrow gb-eyebrow--light">La Metrópolis</p>
      <h2>Núcleo operativo del Reino</h2>
      <p>
        La Metrópolis constituye el centro administrativo del Reino.
        Desde ella se coordinan las Provincias Mayores,
        se conservan los registros institucionales
        y se ejecutan las decisiones superiores.
      </p>
      <p>
        La Metrópolis no es únicamente símbolo;
        es el núcleo desde el cual se mantiene la unidad del sistema.
      </p>
    </div>
    <div class="gb-metro-image" data-reveal="right">
      <img src="/metropolis.png" alt="La Metrópolis de Eucategarion" />
    </div>
  </section>

  <!-- Provincias Mayores — grid de cards -->
  <section class="gb-provinces-section">
    <p class="gb-provinces-eyebrow">Las Provincias Mayores</p>
    <p class="gb-provinces-intro">
      Divisiones funcionales del Reino. Cada una posee competencia definida y autoridad designada.
    </p>

    <!-- Row 1: 2 grandes -->
    <div class="gb-provinces-row gb-provinces-row--2" data-stagger>
      {provinces.slice(0, 2).map((p, i) => (
        <a href={`/gobierno/${p.slug}`} class="gb-prov-card gb-prov-card--large">
          <img src={p.image} alt={p.imageAlt} loading="lazy" />
          <div class="gb-pc-overlay"></div>
          <div class="gb-pc-content">
            <span class="gb-pc-num">Provincia {['I','II','III','IV','V'][i]}</span>
            <h3>{p.name}</h3>
            <p class="gb-pc-latin">{p.latinName}</p>
            <p class="gb-pc-authority">{p.authority}</p>
            <span class="gb-pc-link">Ver Provincia →</span>
          </div>
        </a>
      ))}
    </div>

    <!-- Row 2: 3 compactas -->
    <div class="gb-provinces-row gb-provinces-row--3" data-stagger>
      {provinces.slice(2).map((p, i) => (
        <a href={`/gobierno/${p.slug}`} class="gb-prov-card gb-prov-card--compact">
          <img src={p.image} alt={p.imageAlt} loading="lazy" />
          <div class="gb-pc-overlay"></div>
          <div class="gb-pc-content">
            <span class="gb-pc-num">Provincia {['III','IV','V'][i]}</span>
            <h3>{p.name}</h3>
            <p class="gb-pc-authority">{p.authority}</p>
            <span class="gb-pc-link">Ver →</span>
          </div>
        </a>
      ))}
    </div>
  </section>

</BaseLayout>

<style>
  /* ── Principles ── */
  .gb-principles {
    background: #0b0b0d;
    padding: 5rem 2rem;
    border-bottom: 1px solid rgba(198,167,94,0.12);
  }

  .gb-principles-inner {
    max-width: 1100px;
    margin: 0 auto;
  }

  .gb-eyebrow {
    font-family: 'Cardo', serif;
    font-size: 0.58rem;
    letter-spacing: 0.5em;
    text-transform: uppercase;
    color: rgba(198,167,94,0.4);
    margin: 0 0 2.5rem;
    display: block;
  }

  .gb-eyebrow--light {
    color: rgba(198,167,94,0.45);
  }

  .gb-principles-grid {
    display: flex;
    align-items: flex-start;
    gap: 0;
  }

  .gb-principle {
    flex: 1;
    padding: 0 2.5rem;
  }

  .gb-p-num {
    font-family: 'Cardo', serif;
    font-size: 2rem;
    font-weight: 700;
    color: rgba(198,167,94,0.18);
    display: block;
    line-height: 1;
    margin-bottom: 0.75rem;
  }

  .gb-principle p {
    font-family: 'Cardo', serif;
    font-style: italic;
    font-size: 1.05rem;
    color: rgba(244,241,232,0.72);
    line-height: 1.6;
    margin: 0;
  }

  .gb-p-divider {
    width: 1px;
    height: 80px;
    background: linear-gradient(to bottom, transparent, rgba(198,167,94,0.25), transparent);
    flex-shrink: 0;
    margin-top: 2.5rem;
  }

  /* ── La Metrópolis ── */
  .gb-metropolis {
    display: grid;
    grid-template-columns: 1fr 1fr;
    min-height: 420px;
    border-bottom: 3px solid #c6a75e;
  }

  .gb-metro-content {
    background: #f4f1e8;
    padding: 4rem 3.5rem;
    display: flex;
    flex-direction: column;
    justify-content: center;
  }

  .gb-metro-content h2 {
    font-family: 'Cardo', serif;
    font-size: clamp(1.3rem, 3.5vw, 1.8rem);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: #5a0f1b;
    margin: 0 0 1.5rem;
    padding-bottom: 0.75rem;
    border-bottom: 1px solid rgba(198,167,94,0.3);
    overflow-wrap: break-word;
    word-break: break-word;
  }

  .gb-metro-content p {
    font-family: 'Cormorant Garamond', serif;
    font-size: 0.92rem;
    color: #3a1520;
    line-height: 1.8;
    margin-bottom: 1rem;
    text-align: justify;
    hyphens: auto;
  }

  .gb-metro-image {
    overflow: hidden;
  }

  .gb-metro-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    filter: brightness(0.65) sepia(0.1);
    display: block;
    transition: transform 0.6s ease;
  }

  .gb-metro-image:hover img { transform: scale(1.03); }

  /* ── Provinces ── */
  .gb-provinces-section {
    background: #0b0b0d;
    padding-top: 0;
  }

  .gb-provinces-eyebrow {
    font-family: 'Cardo', serif;
    font-size: 0.58rem;
    letter-spacing: 0.5em;
    text-transform: uppercase;
    color: rgba(198,167,94,0.35);
    text-align: center;
    padding: 3rem 2rem 0;
    margin: 0;
  }

  .gb-provinces-intro {
    font-family: 'Cardo', serif;
    font-style: italic;
    font-size: 0.9rem;
    color: rgba(244,241,232,0.35);
    text-align: center;
    max-width: 60ch;
    margin: 0.75rem auto 1.5rem;
    padding: 0 2rem;
  }

  .gb-provinces-row {
    display: grid;
  }

  .gb-provinces-row--2 {
    grid-template-columns: 1fr 1fr;
  }

  .gb-provinces-row--3 {
    grid-template-columns: 1fr 1fr 1fr;
  }

  .gb-prov-card {
    position: relative;
    overflow: hidden;
    display: block;
    text-decoration: none;
  }

  .gb-prov-card--large { height: 440px; }
  .gb-prov-card--compact { height: 320px; }

  .gb-prov-card img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    filter: brightness(0.45) sepia(0.15);
    transition: filter 0.5s ease, transform 0.6s ease;
    display: block;
  }

  .gb-prov-card:hover img {
    filter: brightness(0.32) sepia(0.25);
    transform: scale(1.04);
  }

  .gb-pc-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to top, rgba(5,2,2,0.94) 0%, rgba(5,2,2,0.1) 55%, transparent 100%);
  }

  .gb-pc-content {
    position: absolute;
    bottom: 0;
    inset-inline: 0;
    padding: 1.75rem 2rem;
  }

  .gb-pc-num {
    font-family: 'Cardo', serif;
    font-size: 0.55rem;
    letter-spacing: 0.35em;
    text-transform: uppercase;
    color: rgba(198,167,94,0.55);
    display: block;
    margin-bottom: 0.4rem;
  }

  .gb-pc-content h3 {
    font-family: 'Cardo', serif;
    font-size: 1.2rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: #f4f1e8;
    margin: 0 0 0.2rem;
    line-height: 1.15;
    overflow-wrap: break-word;
    word-break: break-word;
  }

  .gb-prov-card--compact .gb-pc-content h3 { font-size: 1rem; }

  .gb-pc-latin {
    font-family: 'Cardo', serif;
    font-style: italic;
    font-size: 0.78rem;
    color: rgba(198,167,94,0.5);
    margin: 0 0 0.4rem;
  }

  .gb-pc-authority {
    font-family: 'Cormorant Garamond', serif;
    font-size: 0.72rem;
    color: rgba(244,241,232,0.45);
    margin: 0 0 0.75rem;
  }

  .gb-pc-link {
    font-family: 'Cardo', serif;
    font-size: 0.65rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: #c6a75e;
    border-bottom: 1px solid rgba(198,167,94,0.35);
    padding-bottom: 1px;
    opacity: 0;
    transition: opacity 0.3s;
  }

  .gb-prov-card:hover .gb-pc-link { opacity: 1; }

  /* Top gold line on hover */
  .gb-prov-card::after {
    content: '';
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 2px;
    background: #c6a75e;
    transform: scaleX(0);
    transform-origin: left;
    transition: transform 0.3s ease;
  }

  .gb-prov-card:hover::after { transform: scaleX(1); }

  @media (max-width: 900px) {
    .gb-principles-grid { flex-direction: column; gap: 2rem; }
    .gb-p-divider { width: 80%; height: 1px; margin: 0 auto; }
    .gb-metropolis { grid-template-columns: 1fr; }
    .gb-metro-image { height: 260px; }
    .gb-provinces-row--2,
    .gb-provinces-row--3 { grid-template-columns: 1fr 1fr; }
    .gb-prov-card--large,
    .gb-prov-card--compact { height: 260px; }
  }

  @media (max-width: 600px) {
    .gb-principles { padding: 3rem 1.5rem; }
    .gb-principle { padding: 0 0.25rem; }
    .gb-principle p { font-size: 0.9rem; }
    .gb-p-num { font-size: 1.4rem; }
    .gb-metro-content { padding: 2.5rem 1.5rem; }
    .gb-metro-content h2 { font-size: 1.1rem; letter-spacing: 0.01em; }
    .gb-eyebrow--light { letter-spacing: 0.15em; font-size: 0.5rem; }
    .gb-provinces-row--2,
    .gb-provinces-row--3 { grid-template-columns: 1fr; }
    .gb-prov-card--large,
    .gb-prov-card--compact { height: 250px; }
    .gb-pc-content h3 { font-size: 0.95rem; letter-spacing: 0.04em; }
    .gb-pc-content { padding: 1.25rem 1.25rem; }
    .gb-provinces-eyebrow { letter-spacing: 0.18em; }
    .gb-provinces-intro { font-size: 0.82rem; padding: 0 1.5rem; }
  }
</style>
