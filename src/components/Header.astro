---
---

<header>
  <div class="mh">
    <a href="/" class="mh-crest" aria-label="Inicio — El Trono">
      <img src="/escudo-white.png" alt="Escudo del Reino Soberano de Eucategarion" />
    </a>

    <div class="mh-sep" aria-hidden="true"></div>

    <div class="mh-brand">
      <p class="mh-name">Sacratísimo Reino Soberano de Eucategarion</p>
      <p class="mh-tagline">Trono &nbsp;·&nbsp; Sede Metropolitana &nbsp;·&nbsp; Custodio del Orden</p>
    </div>

    <button class="mh-burger" id="mh-burger" aria-label="Abrir menú" aria-expanded="false">
      <span></span>
      <span></span>
      <span></span>
    </button>
  </div>
</header>

<style>
  header {
    background: #0b0b0d;
    border-top: 3px solid #c6a75e;
    border-bottom: 1px solid rgba(198,167,94,0.18);
    position: relative;
    z-index: 100;
  }

  .mh {
    max-width: 1200px;
    margin: 0 auto;
    padding: 1.25rem 2rem;
    display: grid;
    grid-template-columns: 58px 1px 1fr auto;
    align-items: center;
    gap: 1.75rem;
  }

  .mh-crest { display: block; }
  .mh-crest img { width: 58px; height: auto; display: block; opacity: 0.88; }

  .mh-sep {
    width: 1px;
    height: 44px;
    background: linear-gradient(to bottom, transparent, rgba(198,167,94,0.28), transparent);
  }

  .mh-name {
    font-family: 'Cardo', serif;
    font-size: clamp(0.9rem, 2vw, 1.3rem);
    font-weight: 700;
    color: #c6a75e;
    letter-spacing: 0.02em;
    margin: 0 0 0.18rem;
    line-height: 1.2;
  }

  .mh-tagline {
    font-family: 'Roboto Slab', serif;
    font-size: 0.62rem;
    letter-spacing: 0.1em;
    color: rgba(244,241,232,0.28);
    margin: 0;
    text-transform: uppercase;
  }

  /* Hamburger — visible only on mobile */
  .mh-burger {
    display: none;
    flex-direction: column;
    gap: 5px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 6px;
    margin-left: auto;
  }

  .mh-burger span {
    display: block;
    width: 22px;
    height: 1.5px;
    background: rgba(198,167,94,0.75);
    transition: transform 0.25s, opacity 0.25s;
    transform-origin: center;
  }

  /* Animated to ✕ when active */
  .mh-burger.is-open span:nth-child(1) { transform: translateY(6.5px) rotate(45deg); }
  .mh-burger.is-open span:nth-child(2) { opacity: 0; transform: scaleX(0); }
  .mh-burger.is-open span:nth-child(3) { transform: translateY(-6.5px) rotate(-45deg); }

  @media (max-width: 700px) {
    .mh {
      grid-template-columns: 44px 1px 1fr auto;
      padding: 0.9rem 1.25rem;
      gap: 1rem;
    }
    .mh-crest img { width: 44px; }
    .mh-name { font-size: 0.9rem; }
    .mh-tagline { display: none; }
    .mh-burger { display: flex; }
  }

  @media (max-width: 380px) {
    .mh { grid-template-columns: 38px 1fr auto; gap: 0.75rem; }
    .mh-sep { display: none; }
    .mh-crest img { width: 38px; }
    .mh-name { font-size: 0.82rem; }
  }
</style>
