---
---

<header>
  <div class="mh">
    <a href="/" class="mh-crest" aria-label="Inicio — El Trono">
      <img src="/escudo-white.png" alt="Escudo del Reino Soberano de Eucategarion" />
    </a>

    <div class="mh-sep" aria-hidden="true"></div>

    <div class="mh-brand">
      <p class="mh-name">Sacratísimo Reino Soberano de Eucategarion</p>
      <p class="mh-tagline">Trono &nbsp;·&nbsp; Sede Metropolitana &nbsp;·&nbsp; Custodio del Orden</p>
    </div>

    <button class="mh-burger" id="mh-burger" aria-label="Abrir menú" aria-expanded="false">
      <span></span>
      <span></span>
      <span></span>
    </button>
  </div>
</header>

<style>
  header {
    background: #0b0b0d;
    border-top: 3px solid #c6a75e;
    border-bottom: 1px solid rgba(198,167,94,0.18);
    position: sticky;
    top: 0;
    z-index: 200;
    transition:
      background 0.4s ease,
      border-top-color 0.4s ease,
      border-bottom-color 0.4s ease,
      box-shadow 0.4s ease;
  }

  header.is-scrolled {
    background: rgba(11, 11, 13, 0.82);
    backdrop-filter: blur(22px) saturate(160%);
    -webkit-backdrop-filter: blur(22px) saturate(160%);
    border-top-color: rgba(198, 167, 94, 0.45);
    border-bottom-color: rgba(198, 167, 94, 0.08);
    box-shadow: 0 4px 40px rgba(0, 0, 0, 0.45);
  }

  .mh {
    max-width: 1200px;
    margin: 0 auto;
    padding: 1rem 2rem;
    display: grid;
    grid-template-columns: 78px 1px 1fr auto;
    align-items: center;
    gap: 1.75rem;
    transition: padding 0.35s ease;
  }

  header.is-scrolled .mh {
    padding-top: 0.6rem;
    padding-bottom: 0.6rem;
  }

  .mh-crest { display: block; }
  .mh-crest img { width: 78px; height: auto; display: block; opacity: 0.92; transition: width 0.35s ease, opacity 0.35s ease; }
  header.is-scrolled .mh-crest img { width: 52px; opacity: 0.85; }

  .mh-sep {
    width: 1px;
    height: 58px;
    background: linear-gradient(to bottom, transparent, rgba(198,167,94,0.28), transparent);
    transition: height 0.35s ease;
  }

  header.is-scrolled .mh-sep { height: 40px; }

  .mh-name {
    font-family: 'Cardo', serif;
    font-size: clamp(0.95rem, 2vw, 1.35rem);
    font-weight: 700;
    color: #c6a75e;
    letter-spacing: 0.02em;
    margin: 0 0 0.22rem;
    line-height: 1.2;
  }

  .mh-tagline {
    font-family: 'Cormorant Garamond', serif;
    font-size: 0.72rem;
    letter-spacing: 0.12em;
    color: rgba(244,241,232,0.32);
    margin: 0;
    text-transform: uppercase;
    font-style: italic;
  }

  /* Hamburger — visible only on mobile */
  .mh-burger {
    display: none;
    flex-direction: column;
    gap: 5px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 6px;
    margin-left: auto;
  }

  .mh-burger span {
    display: block;
    width: 22px;
    height: 1.5px;
    background: rgba(198,167,94,0.75);
    transition: transform 0.25s, opacity 0.25s;
    transform-origin: center;
  }

  /* Animated to ✕ when active */
  .mh-burger.is-open span:nth-child(1) { transform: translateY(6.5px) rotate(45deg); }
  .mh-burger.is-open span:nth-child(2) { opacity: 0; transform: scaleX(0); }
  .mh-burger.is-open span:nth-child(3) { transform: translateY(-6.5px) rotate(-45deg); }

  @media (max-width: 700px) {
    .mh {
      grid-template-columns: 54px 1px 1fr auto;
      padding: 0.85rem 1.25rem;
      gap: 1rem;
    }
    .mh-crest img { width: 54px; }
    .mh-name { font-size: 0.92rem; }
    .mh-tagline { display: none; }
    .mh-burger { display: flex; }
  }

  @media (max-width: 380px) {
    .mh { grid-template-columns: 44px 1fr auto; gap: 0.75rem; }
    .mh-sep { display: none; }
    .mh-crest img { width: 44px; }
    .mh-name { font-size: 0.84rem; }
  }
</style>
