---
/**
 * Two modes:
 *  - image provided  → full-bleed cinematic (70vh, image as bg, text bottom-left)
 *  - no image        → dark typographic (black bg, large gold title, centered)
 */
interface Props {
  title: string;
  subtitle?: string;
  image?: string;
  imageAlt?: string;
}

const { title, subtitle, image, imageAlt = '' } = Astro.props;
---

{image ? (
  <section class="hero-film">
    <div class="hero-film-bg" style={`background-image: url('${image}')`}></div>
    <div class="hero-film-overlay"></div>
    <div class="hero-film-content">
      <p class="hf-label">Sacratísimo Reino Soberano &nbsp;·&nbsp; Eucategarion</p>
      <div class="hf-rule"></div>
      <h1 class="hf-title">{title}</h1>
      {subtitle && <p class="hf-subtitle">{subtitle}</p>}
    </div>
    <div class="hf-scroll-hint" aria-hidden="true"></div>
  </section>
) : (
  <section class="hero-dark">
    <div class="hero-dark-inner">
      <p class="hd-label">Sacratísimo Reino Soberano &nbsp;·&nbsp; Eucategarion</p>
      <div class="hd-rule"></div>
      <h1 class="hd-title">{title}</h1>
      <div class="hd-rule hd-rule--inv"></div>
      {subtitle && <p class="hd-subtitle">{subtitle}</p>}
    </div>
  </section>
)}

<style>
  /* ── CINEMATIC IMAGE HERO ── */

  .hero-film {
    position: relative;
    height: 72vh;
    min-height: 520px;
    max-height: 820px;
    display: flex;
    align-items: flex-end;
    overflow: hidden;
    border-bottom: 3px solid #c6a75e;
  }

  .hero-film-bg {
    position: absolute;
    inset: 0;
    background-size: cover;
    background-position: center 30%;
    animation: kenBurns 14s cubic-bezier(0.25, 0.46, 0.45, 0.94) forwards;
  }

  .hero-film-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to bottom,
      rgba(8, 3, 3, 0.08) 0%,
      rgba(8, 3, 3, 0.40) 35%,
      rgba(8, 3, 3, 0.82) 75%,
      rgba(8, 3, 3, 0.95) 100%
    );
  }

  .hero-film-content {
    position: relative;
    z-index: 1;
    padding: 0 3.5rem 3.5rem;
    max-width: 860px;
    min-width: 0;
  }

  .hf-label {
    font-family: 'Cardo', serif;
    font-size: 0.58rem;
    letter-spacing: 0.45em;
    text-transform: uppercase;
    color: rgba(198, 167, 94, 0.7);
    margin: 0 0 1.1rem;
  }

  /* Double rule: 2px cream + gap + 1px gold */
  .hf-rule {
    width: min(480px, 100%);
    height: 4px;
    margin-bottom: 1.5rem;
    background:
      linear-gradient(rgba(244,241,232,0.45), rgba(244,241,232,0.45)) 0 0 / 100% 2px no-repeat,
      linear-gradient(rgba(198,167,94,0.5), rgba(198,167,94,0.5)) 0 3px / 100% 1px no-repeat;
  }

  .hf-title {
    font-family: 'Cardo', serif;
    font-size: clamp(3.5rem, 7.5vw, 7rem);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.09em;
    color: #f4f1e8;
    line-height: 0.92;
    margin: 0 0 1.1rem;
    text-rendering: optimizeLegibility;
  }

  .hf-subtitle {
    font-family: 'Cardo', serif;
    font-style: italic;
    font-size: 1.05rem;
    color: rgba(244, 241, 232, 0.6);
    letter-spacing: 0.03em;
    margin: 0;
  }

  /* ── DARK TYPOGRAPHIC HERO ── */

  .hero-dark {
    background: #0b0b0d;
    padding: 6.5rem 2rem 7rem;
    text-align: center;
    border-bottom: 1px solid rgba(198, 167, 94, 0.18);
  }

  .hero-dark-inner {
    max-width: 760px;
    margin: 0 auto;
  }

  .hd-label {
    font-family: 'Cardo', serif;
    font-size: 0.58rem;
    letter-spacing: 0.45em;
    text-transform: uppercase;
    color: rgba(198, 167, 94, 0.45);
    margin: 0 0 1.25rem;
  }

  /* Gold double rule */
  .hd-rule {
    width: min(85%, 580px);
    margin: 0 auto 1.6rem;
    height: 5px;
    background:
      linear-gradient(rgba(198,167,94,0.75), rgba(198,167,94,0.75)) 0 0 / 100% 3px no-repeat,
      linear-gradient(rgba(198,167,94,0.3), rgba(198,167,94,0.3)) 0 4px / 100% 1px no-repeat;
  }

  /* Inverted: thin gold + thick gold */
  .hd-rule--inv {
    background:
      linear-gradient(rgba(198,167,94,0.3), rgba(198,167,94,0.3)) 0 0 / 100% 1px no-repeat,
      linear-gradient(rgba(198,167,94,0.75), rgba(198,167,94,0.75)) 0 3px / 100% 3px no-repeat;
  }

  .hd-title {
    font-family: 'Cardo', serif;
    font-size: clamp(3.5rem, 9.5vw, 8rem);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: #c6a75e;
    line-height: 0.92;
    margin: 0 0 1.6rem;
    word-spacing: 0.08em;
    text-rendering: optimizeLegibility;
  }

  .hd-subtitle {
    font-family: 'Cardo', serif;
    font-style: italic;
    font-size: 1rem;
    color: rgba(244, 241, 232, 0.45);
    letter-spacing: 0.04em;
    margin: 1.25rem 0 0;
    max-width: 54ch;
    margin-inline: auto;
  }

  /* ── Entrance animations — cinematic hero ── */
  .hf-label    { animation: slideUpIn 0.8s 0.15s cubic-bezier(0.16, 1, 0.3, 1) both; }
  .hf-rule     { animation: slideUpIn 0.7s 0.35s cubic-bezier(0.16, 1, 0.3, 1) both; }
  .hf-title    { animation: slideUpIn 0.9s 0.5s  cubic-bezier(0.16, 1, 0.3, 1) both; }
  .hf-subtitle { animation: slideUpIn 0.7s 0.72s cubic-bezier(0.16, 1, 0.3, 1) both; }

  /* ── Entrance animations — dark typographic hero ── */
  .hd-label    { animation: slideUpIn 0.8s 0.1s  cubic-bezier(0.16, 1, 0.3, 1) both; }
  .hd-rule     { animation: slideUpIn 0.7s 0.28s cubic-bezier(0.16, 1, 0.3, 1) both; }
  .hd-title    { animation: slideUpIn 1s   0.44s cubic-bezier(0.16, 1, 0.3, 1) both; }
  .hd-subtitle { animation: slideUpIn 0.7s 0.78s cubic-bezier(0.16, 1, 0.3, 1) both; }

  /* ── Scroll hint ── */
  .hf-scroll-hint {
    position: absolute;
    bottom: 2.5rem;
    right: 3.5rem;
    width: 1px;
    height: 52px;
    background: linear-gradient(to bottom, rgba(198, 167, 94, 0.65), transparent);
    transform-origin: top;
    animation: scrollPulse 2.4s ease-in-out 1.6s infinite;
  }

  @media (max-width: 700px) {
    .hero-film { height: 60vh; min-height: 360px; }
    .hero-film-content { padding: 0 1.25rem 2rem; }
    .hf-label { letter-spacing: 0.2em; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
    .hf-rule  { width: min(260px, 90%); }
    .hf-title { font-size: clamp(2rem, 9vw, 3.2rem); letter-spacing: 0.05em; }
    .hero-dark { padding: 4rem 1.5rem 4.5rem; }
    .hd-label { letter-spacing: 0.2em; }
    .hd-rule  { width: min(85%, 300px); }
    .hd-title { font-size: clamp(2.2rem, 10vw, 4rem); letter-spacing: 0.05em; }
  }
</style>
