---
import Header from '~/components/Header.astro';
import Menu from '~/components/Menu.astro';
import Footer from '~/components/Footer.astro';
import '~/styles/global.css';

interface Props {
  title: string;
  description?: string;
}

const { title, description = 'Sacratísimo Reino Soberano de Eucategarion, Trono y Sede Metropolitana de las Provincias Digitales y Custodio del Orden' } = Astro.props;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="robots" content="index, follow" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <title>{title}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Cardo:ital,wght@0,400;0,700;1,400&family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;0,600;1,300;1,400;1,500;1,600&display=swap" rel="stylesheet" />
  </head>
  <body>
    <Header />
    <Menu />
    <main>
      <slot />
    </main>
    <Footer />
    <script>
      // ── Scroll reveal ──
      const revealObs = new IntersectionObserver(
        (entries) => {
          entries.forEach((e) => {
            if (e.isIntersecting) {
              e.target.classList.add('is-visible');
              revealObs.unobserve(e.target);
            }
          });
        },
        { threshold: 0.1, rootMargin: '0px 0px -32px 0px' }
      );
      document.querySelectorAll('[data-reveal], [data-stagger]').forEach((el) => revealObs.observe(el));

      // ── Scroll progress bar ──
      const progressBar = document.createElement('div');
      progressBar.className = 'scroll-progress';
      document.body.prepend(progressBar);

      // ── Refs ──
      const header = document.querySelector('header');
      const heroBg = document.querySelector('.hero-film-bg');
      const heroSection = heroBg?.closest('.hero-film');

      // ── Single scroll handler ──
      let ticking = false;
      window.addEventListener('scroll', () => {
        if (!ticking) {
          requestAnimationFrame(() => {
            const y = window.scrollY;
            const maxY = document.documentElement.scrollHeight - window.innerHeight;

            // Progress bar
            progressBar.style.transform = `scaleX(${maxY > 0 ? y / maxY : 0})`;

            // Sticky header class
            if (header) header.classList.toggle('is-scrolled', y > 80);

            // Parallax hero
            if (heroBg && heroSection && y < heroSection.offsetHeight + 300) {
              heroBg.style.backgroundPositionY = `calc(30% + ${(y * 0.28).toFixed(1)}px)`;
            }

            ticking = false;
          });
          ticking = true;
        }
      }, { passive: true });

      // ── 3D tilt on cards ──
      const MAX_TILT = 7;
      document.querySelectorAll('.estructura-card, .gb-prov-card, .rk-inst-card, .realm-card').forEach((card) => {
        const shine = document.createElement('div');
        shine.className = 'card-tilt-shine';
        card.appendChild(shine);

        card.addEventListener('mouseenter', () => {
          card.style.transition = 'transform 0.08s ease';
        });

        card.addEventListener('mousemove', (e) => {
          const r = card.getBoundingClientRect();
          const dx = ((e.clientX - r.left) / r.width - 0.5) * 2;
          const dy = ((e.clientY - r.top)  / r.height - 0.5) * 2;
          card.style.transform = `perspective(900px) rotateX(${(-dy * MAX_TILT).toFixed(2)}deg) rotateY(${(dx * MAX_TILT).toFixed(2)}deg) scale3d(1.025,1.025,1.025)`;
          shine.style.background = `radial-gradient(circle at ${((dx+1)/2*100).toFixed(1)}% ${((dy+1)/2*100).toFixed(1)}%, rgba(198,167,94,0.2) 0%, transparent 65%)`;
          shine.style.opacity = '1';
        });

        card.addEventListener('mouseleave', () => {
          card.style.transition = 'transform 0.55s cubic-bezier(0.16,1,0.3,1)';
          card.style.transform = '';
          shine.style.opacity = '0';
          setTimeout(() => { card.style.transition = ''; }, 600);
        });
      });
    </script>
  </body>
</html>
